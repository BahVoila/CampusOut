<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CampusOut Events</title>
    <link rel="stylesheet" href="styles.css">
    <script src="scripts.js" defer></script>
</head>
<body>
    <header>
        <h1>CampusOut Events</h1>
    </header>
    <main>
        <div class="filters">
            <input type="text" id="search" placeholder="Search events...">
        </div>
        <div id="event-list">
            <!-- Event items will be dynamically populated here -->
        </div>
        <button id="export">Export Events</button>
    </main>
    <footer>
        <p>&copy; 2026 CampusOut</p>
    </footer>
    <script>
        const events = [
            // List of 62 events
            { title: 'Event 1', date: '2026-04-02', time: '10:00 AM' },
            { title: 'Event 2', date: '2026-04-05', time: '1:00 PM' },
            // ... more events ...
        ];

        function displayEvents() {
            const eventList = document.getElementById('event-list');
            events.forEach(event => {
                const div = document.createElement('div');
                div.className = 'event';
                div.innerHTML = `<h2>${event.title}</h2><p>Date: ${event.date}</p><p>Time: ${event.time}</p>`;
                eventList.appendChild(div);
            });
        }

        document.getElementById('search').addEventListener('input', function() {
            const filter = this.value.toLowerCase();
            const eventDivs = document.querySelectorAll('.event');
            eventDivs.forEach(div => {
                const title = div.querySelector('h2').textContent.toLowerCase();
                div.style.display = title.includes(filter) ? 'block' : 'none';
            });
        });

        document.getElementById('export').addEventListener('click', function() {
            // Functionality to export events
        });

        displayEvents();
    </script>
</body>
</html>
